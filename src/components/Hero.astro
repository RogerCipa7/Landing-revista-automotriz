---
import { Icon } from 'astro-icon/components';

const heroContent = {
  image: 'https://images.unsplash.com/photo-1617788138017-80ad40651399?w=1920&q=90',
  title: 'EL FUTURO SOBRE RUEDAS',
  subtitle: 'Descubre innovación, velocidad y diseño en un solo lugar.'
};
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">

  {/* ── Imagen de fondo full-width ── */}
  <div class="absolute inset-0 z-0 bg-white">
    <img
      id="hero-bg"
      src={heroContent.image}
      alt="Hero background"
      class="w-full h-full object-cover object-center scale-110 opacity-60"
      loading="eager"
    />
    {/* Overlay degradado para legibilidad del texto - Tema Light Premium */}
    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent"></div>
    {/* Overlay inferior para suavizar el corte con la siguiente sección */}
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-gray-50 to-transparent"></div>
  </div>

  {/* ── Contenido ── */}
  <div class="relative z-10 w-full px-6 lg:px-12 xl:px-24 py-32 lg:py-0 lg:min-h-screen lg:flex lg:items-center">
    <div class="max-w-3xl">

      {/* Badge */}
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-red-600/15 border border-red-500/40 mb-8 backdrop-blur-sm hero-item" style="--i:0">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
        <span class="text-red-400 text-xs font-semibold uppercase tracking-widest">Edición 2025</span>
      </div>

      {/* Título */}
      <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black text-gray-900 mb-6 tracking-tight leading-[0.95] hero-item" style="--i:1">
        {heroContent.title.split(' ').map((word) => (
          <span class="inline-block hover:text-red-600 transition-colors duration-300 cursor-default mr-4">
            {word}
          </span>
        ))}
      </h1>

      {/* Línea roja */}
      <div class="w-24 h-[3px] bg-gradient-to-r from-red-600 to-red-500 mb-8 rounded-full hero-item" style="--i:2"></div>

      {/* Subtítulo */}
      <p class="text-lg sm:text-xl lg:text-2xl text-gray-600 max-w-xl mb-12 leading-relaxed font-light hero-item" style="--i:3">
        {heroContent.subtitle}
      </p>

      {/* Botones */}
      <div class="flex flex-col sm:flex-row gap-4 hero-item" style="--i:4">
        <a
          href="#modelos"
          class="group inline-flex items-center justify-center gap-2 px-9 py-4 bg-red-600 text-white rounded-full font-bold text-sm tracking-widest uppercase transition-all duration-300 hover:bg-red-700 hover:scale-105 hover:shadow-[0_0_32px_rgba(220,38,38,0.3)] shadow-[0_4px_14px_0_rgba(220,38,38,0.39)]"
        >
          Explorar Modelos
          <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center justify-center gap-2 px-9 py-4 bg-white border border-gray-200 text-gray-700 rounded-full font-bold text-sm tracking-widest uppercase transition-all duration-300 hover:bg-gray-50 hover:text-gray-900 hover:border-gray-300 hover:scale-105 shadow-sm"
        >
          <Icon name="lucide:mail" class="w-4 h-4" />
          Contáctanos
        </a>
      </div>

    </div>
  </div>

  {/* ── Stats flotantes (desktop) ── */}
  <div class="hidden lg:flex absolute bottom-12 right-12 xl:right-24 z-10 gap-8 hero-item" style="--i:5">
    {[
      { num: '500+', label: 'Modelos Exclusivos' },
      { num: '50+', label: 'Marcas Globales' },
      { num: '2.5M+', label: 'Comunidad Activa' },
    ].map((stat) => (
      <div class="text-center bg-white/90 backdrop-blur-md border border-white shadow-xl px-6 py-4 rounded-2xl">
        <p class="text-gray-900 font-serif text-3xl lg:text-4xl font-black leading-none">{stat.num}</p>
        <p class="text-gray-500 text-[10px] lg:text-xs uppercase tracking-[0.2em] mt-2 font-medium">{stat.label}</p>
      </div>
    ))}
  </div>

  {/* ── Scroll indicator ── */}
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce lg:left-12 lg:translate-x-0 xl:left-24">
    <span class="text-gray-400 text-[10px] uppercase tracking-widest">Scroll</span>
    <div class="w-5 h-9 border border-gray-300 rounded-full flex justify-center pt-2">
      <div class="w-1 h-2 bg-gray-400 rounded-full animate-pulse"></div>
    </div>
  </div>

</section>

<script>
  // Parallax effect for hero background
  const heroBg = document.getElementById('hero-bg');
  window.addEventListener('scroll', () => {
    if (heroBg) {
      const scroll = window.scrollY;
      heroBg.style.transform = `translateY(${scroll * 0.4}px) scale(1.1)`;
    }
  }, { passive: true });

  // Intersection Observer for staggered entrance
  const observerOptions = {
    threshold: 0.1
  };

  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const items = entry.target.querySelectorAll('.hero-item');
        items.forEach((item, index) => {
          (item as HTMLElement).style.animationDelay = `${index * 150}ms`;
          item.classList.add('animate-in');
        });
        heroObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  const heroSection = document.getElementById('inicio');
  if (heroSection) heroObserver.observe(heroSection);
</script>

<style>
  @keyframes heroFadeUp {
    from { 
      opacity: 0; 
      transform: translateY(40px) skewY(2deg); 
      filter: blur(10px);
    }
    to { 
      opacity: 1; 
      transform: translateY(0) skewY(0);
      filter: blur(0);
    }
  }

  .hero-item {
    opacity: 0;
  }

  .hero-item.animate-in {
    animation: heroFadeUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }
</style>