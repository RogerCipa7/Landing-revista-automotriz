---

<section id="catalogo" class="py-24 bg-gray-50 w-full relative">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e7eb_1px,transparent_1px),linear-gradient(to_bottom,#e5e7eb_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>

  <div class="w-full px-6 lg:px-12 xl:px-24 relative z-10">
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl lg:text-5xl font-bold text-gray-900 mb-4 tracking-tight">
        CATÁLOGO <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-700">PREMIUM</span>
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto mb-10 text-lg">
        Colección exclusiva de vehículos de alto rendimiento diseñados para dominar el asfalto.
      </p>

      {/* Filtros */}
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {['TODOS', 'SUV', 'DEPORTIVO', 'SEDÁN', 'ELÉCTRICO', 'HYPERCAR', 'PICKUP', 'LUJO'].map((cat) => (
          <button
            class="filter-btn px-6 py-2 rounded-full border border-gray-200 bg-white shadow-sm text-gray-600 text-sm font-semibold backdrop-blur-sm transition-all duration-300 hover:border-red-500 hover:bg-red-50 hover:text-red-600 focus:outline-none"
            data-filter={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
    
    <div id="catalog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {cars.map((car, index) => (
        <div
          class="group bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-md hover:shadow-2xl hover:border-gray-200 transition-all duration-500 cursor-pointer flex flex-col"
          style={`animation: fadeInUp 0.6s ease-out ${index * 0.1}s backwards;`}
          data-car={JSON.stringify(car)}
          onclick="openModalFromCard(this)"
        >
          <div class="relative overflow-hidden w-full aspect-[16/10] flex-shrink-0">
            <!-- Shine effect -->
            <div class="absolute inset-0 z-20 w-[200%] h-full bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-[100%] group-hover:translate-x-[100%] transition-transform duration-1000 ease-out pointer-events-none"></div>
            
            <div class="absolute top-5 left-5 flex gap-2 z-10">
              <span class="bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full text-xs font-bold text-gray-900 outline outline-1 outline-gray-200 shadow-sm">
                {car.type}
              </span>
              <span class="bg-gradient-to-r from-red-600 to-red-700 px-4 py-1.5 rounded-full text-xs font-bold text-white shadow-lg shadow-red-600/20">
                {car.year}
              </span>
            </div>
            
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-[5]"></div>
            
            <img
              src={car.image}
              alt={car.name}
              class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
            />
            
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-300 z-10 flex items-center justify-center">
              <span class="opacity-0 group-hover:opacity-100 bg-white/10 backdrop-blur-md text-white border border-white/20 px-6 py-3 rounded-full font-semibold text-sm transform translate-y-4 group-hover:translate-y-0 transition-all duration-300 shadow-xl flex items-center gap-2">
                Explorar Vehículo <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </span>
            </div>
          </div>
          
          <div class="p-6 md:p-8 flex flex-col justify-between relative z-20 flex-1">
            <div>
              <h3 class="font-serif font-bold text-gray-900 mb-4 group-hover:text-red-600 transition-colors text-2xl">
                {car.name}
              </h3>
              
              <!-- Specs Grid -->
              <div class="grid grid-cols-3 gap-3 mb-6">
                {car.specs.map(spec => (
                  <div class="bg-gray-50 rounded-xl p-3 border border-gray-100 flex flex-col items-center justify-center gap-2">
                    <Icon name={spec.icon} class="w-5 h-5 text-gray-400 group-hover:text-red-500 transition-colors" />
                    <span class="text-xs font-medium text-gray-600 text-center">{spec.text}</span>
                  </div>
                ))}
              </div>
            </div>
            
            <div class="flex justify-between items-center pt-6 border-t border-gray-100 mt-auto">
              <div>
                <span class="text-xs text-gray-500 uppercase tracking-wider font-semibold block mb-1">Precio Base</span>
                <span class="text-xl font-bold text-gray-900">{car.price}</span>
              </div>
              <button class="w-12 h-12 rounded-full bg-white border border-gray-200 text-gray-400 flex items-center justify-center hover:bg-red-600 hover:text-white hover:border-red-600 transition-all duration-300 shadow-sm hover:shadow-lg" onclick="event.stopPropagation(); openModalFromCard(this.closest('[data-car]'))" title="Ver Detalles">
                 <Icon name="lucide:arrow-right" class="w-5 h-5" />
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Modal incluido una sola vez, con client:load para que su JavaScript esté disponible -->
<VehicleDetailModal />

<script>
  function openModalFromCard(element) {
    if (!element) return;
    const carData = element.getAttribute('data-car');
    if (!carData) return;
    try {
      const car = JSON.parse(carData);
      // Disparar un evento personalizado con los datos del vehículo
      const event = new CustomEvent('openVehicleModal', { detail: { vehicle: car } });
      document.dispatchEvent(event);
    } catch (e) {
      console.error('Error parsing car data', e);
    }
  }
  // Hacer la función globalmente accesible para los onclick
  window.openModalFromCard = openModalFromCard;

  // Filtering Logic
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('#catalog-grid > div');

    // Set initial active button
    const initialBtn = document.querySelector('.filter-btn[data-filter="TODOS"]');
    initialBtn?.classList.add('bg-red-600', 'text-white', 'border-red-600');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        // Update active state
        filterBtns.forEach(b => b.classList.remove('bg-red-600', 'text-white', 'border-red-600', 'bg-white', 'text-gray-600', 'border-gray-200'));
        btn.classList.add('bg-red-600', 'text-white', 'border-red-600');

        cards.forEach(card => {
          const carData = JSON.parse(card.getAttribute('data-car') || '{}');
          const isMatch = filter === 'TODOS' || carData.type === filter;

          if (isMatch) {
            card.style.display = 'block';
            setTimeout(() => {
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            }, 10);
          } else {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
              card.style.display = 'none';
            }, 300);
          }
        });
      });
    });
  });
</script>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>