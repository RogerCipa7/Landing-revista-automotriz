---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { Icon } from 'astro-icon/components';

// Esta función getStaticPaths es requerida por Astro para rutas dinámicas.
// En un caso real, esto vendría de un CMS o una base de datos.
export async function getStaticPaths() {
  const cars = [
    {
      name: 'Porsche Cayenne S',
      type: 'SUV Premium',
      price: '$113,000',
      image: 'https://images.unsplash.com/photo-1503376712351-54c330752495?w=1200&q=80',
      specs: [
        { icon: 'lucide:gauge', text: '468 hp' },
        { icon: 'lucide:timer', text: '4.4s 0-100' },
        { icon: 'lucide:fuel', text: 'V8 Biturbo' }
      ],
      description: 'El Porsche Cayenne S redefine la experiencia de conducir un SUV. Con un motor V8 biturbo excepcionalmente potente, dinámica de conducción inigualable y un interior que combina el lujo supremo con la tecnología más avanzada de Stuttgart.',
      features: ['Suspensión Neumática Adaptativa', 'Frenos de Compuesto Cerámico (PCCB)', 'Paquete Sport Chrono', 'Sistema de Sonido Burmester® 3D High-End Surround']
    },
    {
      name: 'Mercedes-AMG GT',
      type: 'Deportivo',
      price: '$180,000',
      image: 'https://images.unsplash.com/photo-1617788138017-80ad40651399?w=1200&q=80',
      specs: [
        { icon: 'lucide:gauge', text: '577 hp' },
        { icon: 'lucide:timer', text: '3.1s 0-100' },
        { icon: 'lucide:zap', text: 'AWD' }
      ],
      description: 'Un Gran Turismo sin compromisos. El Mercedes-AMG GT está desarrollado íntegramente por AMG para ofrecer unas prestaciones al nivel de las pistas de carreras, pero envuelto en una carrocería de elegancia atemporal y con un confort sorprendente para los viajes largos.',
      features: ['Eje trasero direccional AMG', 'AMG RIDE CONTROL+', 'Asientos AMG Performance', 'Aerodinámica activa']
    },
    {
      name: 'BMW M5 Competition',
      type: 'Sedán',
      price: '$140,000',
      image: 'https://images.unsplash.com/photo-1555529771-50e5ff71f6cd?w=1200&q=80',
      specs: [
        { icon: 'lucide:gauge', text: '617 hp' },
        { icon: 'lucide:timer', text: '3.3s 0-100' },
        { icon: 'lucide:shield-check', text: 'M xDrive' }
      ],
      description: 'La máxima autoridad en berlinas deportivas de alto rendimiento. El M5 Competition fusiona la versatilidad de un sedán ejecutivo con la agresividad y dinámica de un superdeportivo, gracias a su sistema inteligente de tracción en las cuatro ruedas M xDrive y su sublime V8.',
      features: ['Frenos de carbono M', 'Sistema de escape M Sport', 'Diferencial M Activo', 'Asientos multifunción M']
    },
  ];

  return cars.map(car => ({
    params: { id: car.name.toLowerCase().replace(/[\s-]/g, '') },
    props: { car },
  }));
}

const { car } = Astro.props;
---

<BaseLayout title={`${car.name} - Revista Automotriz`}>
  <Navigation />
  
  <main class="bg-gray-50 min-h-screen pt-24 pb-20">
    <div class="px-6 lg:px-12 xl:px-24 max-w-7xl mx-auto pt-10">
      
      {/* ── Breadcrumb & Categoría ── */}
      <div class="mb-8 pl-1 flex items-center gap-2 text-gray-500 text-xs font-bold uppercase tracking-widest">
        <a href="/" class="hover:text-red-600 transition-colors">Inicio</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <a href="/catalogo" class="hover:text-red-600 transition-colors">Catálogo</a>
        <Icon name="lucide:chevron-right" class="w-3 h-3" />
        <span class="text-red-600">{car.type}</span>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-start">
        {/* ── Galería de Imágenes (Simulada con la principal) ── */}
        <div class="relative group rounded-3xl overflow-hidden shadow-2xl border border-gray-200">
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent z-10"></div>
          <img 
            src={car.image} 
            alt={car.name} 
            class="w-full h-auto aspect-video object-cover transition-transform duration-700 group-hover:scale-105"
          />
          {/* Badge precio visual encima de foto */}
          <div class="absolute bottom-6 right-6 z-20 px-6 py-3 bg-red-600/90 backdrop-blur-md text-white font-black text-2xl rounded-2xl shadow-lg shadow-red-600/20">
            {car.price}
          </div>
        </div>

        {/* ── Detalles del Vehículo ── */}
        <div class="flex flex-col gap-8">
          <div>
            <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-gray-900 mb-4 leading-tight">
              {car.name}
            </h1>
            <p class="text-gray-600 text-lg leading-relaxed">
              {car.description}
            </p>
          </div>

          {/* Especificaciones */}
          <div class="grid grid-cols-3 gap-4 border-y border-gray-200 py-8">
            {car.specs.map(spec => (
              <div class="flex flex-col items-center justify-center p-4 bg-white rounded-2xl border border-gray-100 shadow-sm">
                <Icon name={spec.icon} class="w-6 h-6 text-red-600 mb-3" />
                <span class="text-gray-800 font-bold text-sm lg:text-base text-center">{spec.text}</span>
              </div>
            ))}
          </div>

          {/* Características Clave */}
          <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
            <h3 class="font-serif text-2xl font-black text-gray-900 mb-6 flex items-center gap-3">
              <Icon name="lucide:check-circle" class="text-red-600 w-6 h-6" /> Equipamiento Destacado
            </h3>
            <ul class="space-y-4">
              {car.features.map(feature => (
                <li class="flex items-start gap-3">
                  <Icon name="lucide:check" class="text-red-500 w-5 h-5 flex-shrink-0 mt-0.5" />
                  <span class="text-gray-600 text-sm">{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          {/* CTA */}
          <div class="flex gap-4 pt-4">
             <button class="flex-1 bg-red-600 hover:bg-red-700 text-white font-bold text-sm tracking-widest uppercase py-4 rounded-full transition-all shadow-md">
               Reservar Prueba
             </button>
             <button class="px-8 bg-white hover:bg-gray-50 text-gray-700 font-bold text-sm tracking-widest uppercase py-4 rounded-full transition-all border border-gray-200 hover:text-gray-900 shadow-sm">
               Catálogo PDF
             </button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
